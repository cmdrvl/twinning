{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cmdrvl.com/schemas/twinning.v0.schema.json",
  "title": "twinning.v0",
  "description": "Deterministic twinning report artifact for bootstrap, run-once, and interactive report boundaries.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "outcome",
    "mode",
    "engine",
    "host",
    "port",
    "wire_protocol",
    "schema",
    "catalog",
    "storage",
    "tables",
    "constraints",
    "snapshot",
    "next_step"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "twinning.v0"
    },
    "outcome": {
      "type": "string",
      "enum": ["READY", "PASS", "FAIL", "REFUSAL"]
    },
    "mode": {
      "type": "string",
      "enum": ["bootstrap", "interactive", "run_once"]
    },
    "engine": {
      "type": "string",
      "const": "postgres"
    },
    "host": {
      "type": "string",
      "minLength": 1
    },
    "port": {
      "type": "integer",
      "minimum": 0,
      "maximum": 65535
    },
    "wire_protocol": {
      "type": "string",
      "minLength": 1
    },
    "schema": {
      "$ref": "#/$defs/summary"
    },
    "verify_artifact": {
      "$ref": "#/$defs/verify_artifact"
    },
    "catalog": {
      "$ref": "#/$defs/catalog_summary"
    },
    "storage": {
      "$ref": "#/$defs/storage"
    },
    "tables": {
      "type": "object",
      "description": "Per-table twin metrics keyed by canonical schema.table name.",
      "additionalProperties": {
        "$ref": "#/$defs/table_report"
      }
    },
    "constraints": {
      "$ref": "#/$defs/constraint_counters"
    },
    "verify": {
      "$ref": "#/$defs/verify_report"
    },
    "snapshot": {
      "$ref": "#/$defs/snapshot_report"
    },
    "run": {
      "$ref": "#/$defs/run_report"
    },
    "null_rates": {
      "$ref": "#/$defs/ratio_map"
    },
    "fk_coverage": {
      "$ref": "#/$defs/ratio_map"
    },
    "warnings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "next_step": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "hash",
        "table_count",
        "column_count",
        "index_count",
        "constraint_count"
      ],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "hash": {
          "$ref": "#/$defs/sha256"
        },
        "table_count": {
          "type": "integer",
          "minimum": 0
        },
        "column_count": {
          "type": "integer",
          "minimum": 0
        },
        "index_count": {
          "type": "integer",
          "minimum": 0
        },
        "constraint_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "catalog_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dialect",
        "table_count",
        "column_count",
        "index_count",
        "constraint_count"
      ],
      "properties": {
        "dialect": {
          "type": "string",
          "minLength": 1
        },
        "table_count": {
          "type": "integer",
          "minimum": 0
        },
        "column_count": {
          "type": "integer",
          "minimum": 0
        },
        "index_count": {
          "type": "integer",
          "minimum": 0
        },
        "constraint_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tournament_mode",
        "replay_mode",
        "hot_working_set",
        "cold_state"
      ],
      "properties": {
        "tournament_mode": {
          "type": "string",
          "minLength": 1
        },
        "replay_mode": {
          "type": "string",
          "minLength": 1
        },
        "hot_working_set": {
          "type": "string",
          "minLength": 1
        },
        "cold_state": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "table_report": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rows", "columns", "indexes", "constraints"],
      "properties": {
        "rows": {
          "type": "integer",
          "minimum": 0
        },
        "expected": {
          "type": "integer",
          "minimum": 0
        },
        "coverage": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "columns": {
          "type": "integer",
          "minimum": 0
        },
        "indexes": {
          "type": "integer",
          "minimum": 0
        },
        "constraints": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "constraint_counters": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "not_null_violations",
        "fk_violations",
        "check_violations",
        "unique_violations"
      ],
      "properties": {
        "not_null_violations": {
          "type": "integer",
          "minimum": 0
        },
        "fk_violations": {
          "type": "integer",
          "minimum": 0
        },
        "check_violations": {
          "type": "integer",
          "minimum": 0
        },
        "unique_violations": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "verify_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "hash", "loaded"],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "hash": {
          "$ref": "#/$defs/sha256"
        },
        "loaded": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "verify_report": {
      "type": "object",
      "description": "Embedded verify.report.v1 payload preserved without twinning-local reinterpretation.",
      "additionalProperties": false,
      "required": [
        "tool",
        "version",
        "execution_mode",
        "outcome",
        "constraint_set_id",
        "constraint_hash",
        "bindings",
        "summary",
        "policy_signals",
        "results",
        "refusal"
      ],
      "properties": {
        "tool": {
          "const": "verify"
        },
        "version": {
          "const": "verify.report.v1"
        },
        "execution_mode": {
          "enum": ["batch", "embedded"]
        },
        "outcome": {
          "enum": ["PASS", "FAIL", "REFUSAL"]
        },
        "constraint_set_id": {
          "type": "string",
          "minLength": 1
        },
        "constraint_hash": {
          "$ref": "#/$defs/sha256"
        },
        "bindings": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "minLength": 1
          },
          "additionalProperties": {
            "$ref": "#/$defs/verify_binding_report"
          }
        },
        "summary": {
          "$ref": "#/$defs/verify_summary"
        },
        "policy_signals": {
          "$ref": "#/$defs/verify_policy_signals"
        },
        "results": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/verify_rule_result"
          }
        },
        "refusal": {
          "oneOf": [
            {
              "$ref": "#/$defs/verify_refusal"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "outcome": {
                "const": "REFUSAL"
              }
            }
          },
          "then": {
            "properties": {
              "refusal": {
                "$ref": "#/$defs/verify_refusal"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "outcome": {
                "enum": ["PASS", "FAIL"]
              }
            }
          },
          "then": {
            "properties": {
              "refusal": {
                "type": "null"
              }
            }
          }
        }
      ]
    },
    "verify_binding_report": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "source", "content_hash"],
      "properties": {
        "kind": {
          "const": "relation"
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "content_hash": {
          "$ref": "#/$defs/sha256"
        },
        "input_verification": {
          "oneOf": [
            {
              "$ref": "#/$defs/verify_input_verification"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "verify_input_verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "locks"],
      "properties": {
        "status": {
          "enum": ["VERIFIED"]
        },
        "locks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "verify_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total_rules", "passed_rules", "failed_rules", "by_severity"],
      "properties": {
        "total_rules": {
          "type": "integer",
          "minimum": 0
        },
        "passed_rules": {
          "type": "integer",
          "minimum": 0
        },
        "failed_rules": {
          "type": "integer",
          "minimum": 0
        },
        "by_severity": {
          "$ref": "#/$defs/verify_by_severity"
        }
      }
    },
    "verify_by_severity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["error", "warn"],
      "properties": {
        "error": {
          "type": "integer",
          "minimum": 0
        },
        "warn": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "verify_policy_signals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["severity_band"],
      "properties": {
        "severity_band": {
          "enum": ["CLEAN", "WARN_ONLY", "ERROR_PRESENT"]
        }
      }
    },
    "verify_rule_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_id", "severity", "status", "violation_count", "affected"],
      "properties": {
        "rule_id": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "enum": ["error", "warn"]
        },
        "status": {
          "enum": ["pass", "fail"]
        },
        "violation_count": {
          "type": "integer",
          "minimum": 0
        },
        "affected": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/verify_affected_entry"
          }
        }
      }
    },
    "verify_affected_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["binding"],
      "properties": {
        "binding": {
          "type": "string",
          "minLength": 1
        },
        "key": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "minLength": 1
          },
          "additionalProperties": {
            "$ref": "#/$defs/verify_scalar"
          }
        },
        "field": {
          "type": "string",
          "minLength": 1
        },
        "value": true
      }
    },
    "verify_scalar": {
      "type": ["string", "number", "boolean", "null"]
    },
    "verify_refusal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "detail", "next_step"],
      "properties": {
        "code": {
          "enum": [
            "E_IO",
            "E_BAD_CONSTRAINTS",
            "E_BAD_AUTHORING",
            "E_DUPLICATE_BINDING",
            "E_MISSING_BINDING",
            "E_UNDECLARED_BINDING",
            "E_FORMAT_DETECT",
            "E_FIELD_NOT_FOUND",
            "E_BAD_EXPR",
            "E_SQL_ERROR",
            "E_BATCH_ONLY_RULE",
            "E_KEY_CONFLICT",
            "E_INPUT_NOT_LOCKED",
            "E_INPUT_DRIFT",
            "E_TOO_LARGE"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "detail": true,
        "next_step": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "snapshot_report": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "restored_from": {
          "type": "string",
          "minLength": 1
        },
        "written_to": {
          "type": "string",
          "minLength": 1
        },
        "snapshot_hash": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "run_report": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "timed_out"],
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "exit_code": {
          "type": "integer"
        },
        "signal": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "timed_out": {
          "type": "boolean"
        }
      }
    },
    "ratio_map": {
      "type": "object",
      "additionalProperties": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      }
    }
  }
}
