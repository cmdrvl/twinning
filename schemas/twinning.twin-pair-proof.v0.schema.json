{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cmdrvl.com/schemas/twinning.twin-pair-proof.v0.schema.json",
  "title": "twinning.twin-pair-proof.v0",
  "description": "Prototype interface-equivalence receipt for comparing two Postgres twins over one declared subset.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "proof_id",
    "outcome",
    "endpoints",
    "cases"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "twinning.twin-pair-proof.v0"
    },
    "proof_id": {
      "type": "string",
      "minLength": 1
    },
    "outcome": {
      "type": "string",
      "enum": [
        "PASS",
        "FAIL"
      ]
    },
    "catalog_declaration": {
      "$ref": "#/$defs/catalog_declaration"
    },
    "endpoints": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "#/$defs/endpoint"
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/case"
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "catalog_declaration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "hash",
        "version",
        "declaration_id",
        "catalog_version",
        "source_deployment_fingerprint",
        "outcome_tags",
        "table_keys"
      ],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "hash": {
          "$ref": "#/$defs/sha256"
        },
        "version": {
          "type": "string",
          "const": "twinning.catalog-declaration.v0"
        },
        "declaration_id": {
          "type": "string",
          "minLength": 1
        },
        "catalog_version": {
          "type": "string",
          "minLength": 1
        },
        "source_deployment_fingerprint": {
          "$ref": "#/$defs/sha256"
        },
        "outcome_tags": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "table_keys": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "endpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "endpoint_id",
        "role",
        "engine",
        "snapshot_hash",
        "committed_state_hash"
      ],
      "properties": {
        "endpoint_id": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "engine": {
          "type": "string",
          "const": "postgres"
        },
        "snapshot_hash": {
          "$ref": "#/$defs/sha256"
        },
        "committed_state_hash": {
          "$ref": "#/$defs/sha256"
        },
        "catalog_declaration_hash": {
          "$ref": "#/$defs/sha256"
        },
        "source_materialization": {
          "$ref": "#/$defs/source_materialization"
        },
        "evidence_identities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_identity"
          }
        }
      }
    },
    "source_materialization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_identity",
        "method",
        "table_count",
        "row_count",
        "tables"
      ],
      "properties": {
        "source_identity": {
          "$ref": "#/$defs/sha256"
        },
        "method": {
          "type": "string",
          "enum": [
            "psql_copy_stdout",
            "manifest_sql_load"
          ]
        },
        "table_count": {
          "type": "integer",
          "minimum": 0
        },
        "row_count": {
          "type": "integer",
          "minimum": 0
        },
        "tables": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "evidence_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_kind",
        "artifact_id",
        "version",
        "hash"
      ],
      "properties": {
        "artifact_kind": {
          "type": "string",
          "enum": [
            "verify",
            "benchmark",
            "assess"
          ]
        },
        "artifact_id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "hash": {
          "$ref": "#/$defs/sha256"
        },
        "source": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "verdict",
        "left",
        "right",
        "replay_result"
      ],
      "properties": {
        "case_id": {
          "type": "string",
          "minLength": 1
        },
        "verdict": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "skip"
          ]
        },
        "left": {
          "$ref": "#/$defs/observation"
        },
        "right": {
          "$ref": "#/$defs/observation"
        },
        "replay_result": {
          "$ref": "#/$defs/replay_result"
        },
        "mismatches": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "endpoint_id",
        "snapshot_hash",
        "query_id",
        "result_hash",
        "result"
      ],
      "properties": {
        "endpoint_id": {
          "type": "string",
          "minLength": 1
        },
        "snapshot_hash": {
          "$ref": "#/$defs/sha256"
        },
        "query_id": {
          "type": "string",
          "minLength": 1
        },
        "result_hash": {
          "$ref": "#/$defs/sha256"
        },
        "result": true
      }
    },
    "replay_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "query_id",
        "left_endpoint_id",
        "right_endpoint_id",
        "left_snapshot_hash",
        "right_snapshot_hash",
        "left_result_hash",
        "right_result_hash",
        "result_hashes_match",
        "row_count_parity",
        "command_tag_parity",
        "sqlstate_parity",
        "refusal_parity",
        "ordering_policy_parity"
      ],
      "properties": {
        "version": {
          "type": "string",
          "const": "twinning.twin-pair-replay-result.v0"
        },
        "query_id": {
          "type": "string",
          "minLength": 1
        },
        "left_endpoint_id": {
          "type": "string",
          "minLength": 1
        },
        "right_endpoint_id": {
          "type": "string",
          "minLength": 1
        },
        "left_snapshot_hash": {
          "$ref": "#/$defs/sha256"
        },
        "right_snapshot_hash": {
          "$ref": "#/$defs/sha256"
        },
        "left_result_hash": {
          "$ref": "#/$defs/sha256"
        },
        "right_result_hash": {
          "$ref": "#/$defs/sha256"
        },
        "result_hashes_match": {
          "type": "boolean"
        },
        "row_count_parity": {
          "$ref": "#/$defs/optional_u64_parity"
        },
        "command_tag_parity": {
          "$ref": "#/$defs/optional_string_parity"
        },
        "sqlstate_parity": {
          "$ref": "#/$defs/sqlstate_parity"
        },
        "refusal_parity": {
          "$ref": "#/$defs/optional_string_parity"
        },
        "ordering_policy_parity": {
          "$ref": "#/$defs/optional_string_parity"
        },
        "skip_reason_code": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "optional_u64_parity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "matches"
      ],
      "properties": {
        "left": {
          "type": "integer",
          "minimum": 0
        },
        "right": {
          "type": "integer",
          "minimum": 0
        },
        "matches": {
          "type": "boolean"
        }
      }
    },
    "optional_string_parity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "matches"
      ],
      "properties": {
        "left": {
          "type": "string",
          "minLength": 1
        },
        "right": {
          "type": "string",
          "minLength": 1
        },
        "matches": {
          "type": "boolean"
        }
      }
    },
    "sqlstate_parity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "matches"
      ],
      "properties": {
        "left": {
          "type": "string",
          "pattern": "^[0-9A-Z]{5}$"
        },
        "right": {
          "type": "string",
          "pattern": "^[0-9A-Z]{5}$"
        },
        "matches": {
          "type": "boolean"
        }
      }
    }
  }
}
