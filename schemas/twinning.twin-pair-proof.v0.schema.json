{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cmdrvl.com/schemas/twinning.twin-pair-proof.v0.schema.json",
  "title": "twinning.twin-pair-proof.v0",
  "description": "Prototype interface-equivalence receipt for comparing two Postgres twins over one declared subset.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "proof_id",
    "outcome",
    "endpoints",
    "cases"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "twinning.twin-pair-proof.v0"
    },
    "proof_id": {
      "type": "string",
      "minLength": 1
    },
    "outcome": {
      "type": "string",
      "enum": [
        "PASS",
        "FAIL"
      ]
    },
    "catalog_declaration": {
      "$ref": "#/$defs/catalog_declaration"
    },
    "endpoints": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "#/$defs/endpoint"
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/case"
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "catalog_declaration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "hash",
        "version",
        "declaration_id",
        "catalog_version",
        "source_deployment_fingerprint",
        "outcome_tags",
        "table_keys"
      ],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "hash": {
          "$ref": "#/$defs/sha256"
        },
        "version": {
          "type": "string",
          "const": "twinning.catalog-declaration.v0"
        },
        "declaration_id": {
          "type": "string",
          "minLength": 1
        },
        "catalog_version": {
          "type": "string",
          "minLength": 1
        },
        "source_deployment_fingerprint": {
          "$ref": "#/$defs/sha256"
        },
        "outcome_tags": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "table_keys": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "endpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "endpoint_id",
        "role",
        "engine",
        "snapshot_hash",
        "committed_state_hash"
      ],
      "properties": {
        "endpoint_id": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "engine": {
          "type": "string",
          "const": "postgres"
        },
        "snapshot_hash": {
          "$ref": "#/$defs/sha256"
        },
        "committed_state_hash": {
          "$ref": "#/$defs/sha256"
        },
        "catalog_declaration_hash": {
          "$ref": "#/$defs/sha256"
        },
        "evidence_identities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_identity"
          }
        }
      }
    },
    "evidence_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_kind",
        "artifact_id",
        "version",
        "hash"
      ],
      "properties": {
        "artifact_kind": {
          "type": "string",
          "enum": [
            "verify",
            "benchmark",
            "assess"
          ]
        },
        "artifact_id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "hash": {
          "$ref": "#/$defs/sha256"
        },
        "source": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "verdict",
        "left",
        "right"
      ],
      "properties": {
        "case_id": {
          "type": "string",
          "minLength": 1
        },
        "verdict": {
          "type": "string",
          "enum": [
            "pass",
            "fail"
          ]
        },
        "left": {
          "$ref": "#/$defs/observation"
        },
        "right": {
          "$ref": "#/$defs/observation"
        },
        "mismatches": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "endpoint_id",
        "query_id",
        "result_hash",
        "result"
      ],
      "properties": {
        "endpoint_id": {
          "type": "string",
          "minLength": 1
        },
        "query_id": {
          "type": "string",
          "minLength": 1
        },
        "result_hash": {
          "$ref": "#/$defs/sha256"
        },
        "result": true
      }
    }
  }
}
